{
  "compilerOptions": {
    "target": "es2022",
    "module": "commonjs",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "outDir": "./dist",
    "types": ["node"]
  },
  "ts-node": {
    "esm": false
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules"]
}
